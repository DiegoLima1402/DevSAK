<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DevSAK.Views.SmtpTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ApplicationTileBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ApplicationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20,12" BorderBrush="{ThemeResource ApplicationBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Button x:Name="BackButton"
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" FontFamily="Segoe Fluent Icons" />
                        <TextBlock Text="Voltar" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE715;"
                              Foreground="{ThemeResource ApplicationAccentBrush}"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="20" />
                    <TextBlock Text="Testar SMTP" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel HorizontalAlignment="Center" MaxWidth="1100" Spacing="24">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="20">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel Spacing="18">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE715;"
                                              FontSize="18"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource ApplicationAccentBrush}"
                                              FontFamily="Segoe Fluent Icons" />
                                    <TextBlock Text="Configuração SMTP" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>

                                <Grid ColumnSpacing="14" RowSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Servidor SMTP" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <TextBox Text="{Binding SmtpServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="smtp.exemplo.com" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Text="Porta" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <NumberBox Value="{Binding Port, Mode=TwoWay}"
                                                   Minimum="1"
                                                   Maximum="65535"
                                                   SmallChange="1"
                                                   SpinButtonPlacementMode="Compact" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Spacing="6">
                                        <TextBlock Text="Usuário" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <TextBox Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="usuario@dominio.com" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                        <TextBlock Text="Senha" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <PasswordBox Password="{Binding Password, Mode=TwoWay}"
                                                     PlaceholderText="Senha" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Spacing="6">
                                        <TextBlock Text="Email do remetente" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <TextBox Text="{Binding SenderEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="remetente@dominio.com" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                                        <TextBlock Text="Email do destinatário" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <TextBox Text="{Binding RecipientEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="destino@dominio.com" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="6">
                                        <TextBlock Text="Assunto" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <TextBox Text="{Binding Subject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="Assunto da mensagem de teste" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Mensagem" FontWeight="Medium" FontSize="13" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBox Text="{Binding Message, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Digite a mensagem que será usada no teste SMTP"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="140" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE713;"
                                              FontSize="18"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource ApplicationAccentBrush}"
                                              FontFamily="Segoe Fluent Icons" />
                                    <TextBlock Text="Opções" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>

                                <Grid ColumnSpacing="18" RowSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <CheckBox Content="SSL"
                                              IsChecked="{Binding UseSsl, Mode=TwoWay}" />
                                    <CheckBox Grid.Column="1"
                                              Content="STARTTLS"
                                              IsChecked="{Binding UseStartTls, Mode=TwoWay}" />
                                    <CheckBox Grid.Row="1"
                                              Content="Autenticação habilitada"
                                              IsChecked="{Binding AuthenticationEnabled, Mode=TwoWay}" />
                                    <CheckBox Grid.Row="1"
                                              Grid.Column="1"
                                              Content="Usar credenciais do usuário"
                                              IsChecked="{Binding UseUserCredentials, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="20">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE9D9;"
                                              FontSize="18"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource ApplicationAccentBrush}"
                                              FontFamily="Segoe Fluent Icons" />
                                    <TextBlock Text="Execução" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource ApplicationSubTextBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ProgressText, Mode=OneWay}"
                                                   HorizontalAlignment="Right"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource ApplicationAccentBrush}" />
                                    </Grid>

                                    <ProgressBar Value="{Binding Progress}"
                                                 Height="6" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                    <Button Content="Limpar campos"
                                            Click="ClearFieldsButton_Click"
                                            IsEnabled="{Binding CanTest}" />
                                    <Button Content="Cancelar"
                                            Click="CancelButton_Click"
                                            IsEnabled="{Binding CanCancel}" />
                                    <Button Content="Testar SMTP"
                                            Click="TestSmtpButton_Click"
                                            IsEnabled="{Binding CanTest}"
                                            Background="{ThemeResource ApplicationAccentBrush}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Padding="24,10"
                                            CornerRadius="8" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Console de Saída" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <ToggleButton Content="Auto-rolagem"
                                                      IsChecked="{Binding AutoScrollEnabled, Mode=TwoWay}" />
                                        <Button Content="Copiar log"
                                                Click="CopyLogButton_Click" />
                                        <Button Content="Limpar log"
                                                Click="ClearLogButton_Click" />
                                    </StackPanel>
                                </Grid>

                                <TextBox x:Name="LogTextBox"
                                         Text="{Binding LogText}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         Height="360"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="12"
                                         Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                         BorderThickness="1"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         TextChanged="LogTextBox_TextChanged" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
