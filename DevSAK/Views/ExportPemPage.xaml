<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DevSAK.Views.ExportPemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DevSAK.Converters"
    xmlns:community="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationBackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ApplicationTileBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ApplicationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,12" BorderBrush="{ThemeResource ApplicationBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Button x:Name="BackButton"
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" FontFamily="Segoe Fluent Icons" />
                        <TextBlock Text="Voltar" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xEB95;" Foreground="{ThemeResource ApplicationAccentBrush}" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Ferramentas de Certificado" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel HorizontalAlignment="Center" MaxWidth="1200" Spacing="24">

                <community:Segmented x:Name="ModePicker"
                                     HorizontalAlignment="Stretch"
                                     SelectionChanged="ModePicker_SelectionChanged">
                    <community:SegmentedItem Content="Exportar PEM" IsSelected="True" />
                    <community:SegmentedItem Content="Validar Certificado" />
                </community:Segmented>

                <StackPanel x:Name="ExportSection" Spacing="16" Visibility="Visible">

                    <InfoBar IsOpen="{Binding IsErrorVisible}"
                             Severity="Error"
                             Title="Atenção"
                             Message="{Binding ErrorText}"
                             IsClosable="False"
                             Margin="0,0,0,4" />

                    <InfoBar IsOpen="{Binding IsWarningVisible}"
                             Severity="Warning"
                             Title="Aviso"
                             Message="{Binding WarningText}"
                             IsClosable="True"
                             Margin="0,0,0,12" />

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Entrada" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Arquivo do certificado" FontWeight="SemiBold" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding InputCertificatePath, Mode=TwoWay}" PlaceholderText="Selecione um .pfx/.p12 (ou .cer/.crt para exportação pública)" />
                                            <Button Grid.Column="1" Click="BrowseCertificateButton_Click" ToolTipService.ToolTip="Escolher arquivo">
                                                <FontIcon Glyph="&#xED25;" FontSize="16" FontFamily="Segoe Fluent Icons" />
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="Dica: .cer/.crt só permite exportar o certificado público (sem chave privada)."
                                                   FontSize="12"
                                                   Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Senha do certificado (se aplicável)" FontWeight="SemiBold" />
                                        <PasswordBox Password="{Binding Password, Mode=TwoWay}" PlaceholderText="Senha do .pfx/.p12" />
                                        <TextBlock Text="Obrigatório para .pfx/.p12."
                                                   FontSize="12"
                                                   Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Saída" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,8" />

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Modo de exportação" FontWeight="SemiBold" />
                                        <StackPanel Spacing="6">
                                            <RadioButtons SelectedIndex="{Binding ExportMode, Mode=TwoWay}">
                                                <RadioButton Content="Apenas chave pública PEM" />
                                                <RadioButton Content="Apenas chave privada PEM" IsEnabled="{Binding CanExportPrivateKey}" />
                                                <RadioButton Content="Dois arquivos PEM separados" IsEnabled="{Binding CanExportPrivateKey}" />
                                                <RadioButton Content="Um único arquivo PEM combinado" IsEnabled="{Binding CanExportPrivateKey}" />
                                            </RadioButtons>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Pasta de saída" FontWeight="SemiBold" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding OutputFolder, Mode=TwoWay}" PlaceholderText="Escolha a pasta onde os .pem serão gerados" />
                                            <Button Grid.Column="1" Click="BrowseOutputFolderButton_Click" ToolTipService.ToolTip="Escolher pasta">
                                                <FontIcon Glyph="&#xED25;" FontSize="16" FontFamily="Segoe Fluent Icons" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Nome base do arquivo" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding OutputBaseFileName, Mode=TwoWay}" PlaceholderText="Ex: certificado-prod" />
                                        <TextBlock Text="O sistema gera automaticamente os sufixos: .cert.pem / .key.pem / .pem"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    </StackPanel>

                                    <StackPanel Spacing="10" Visibility="{Binding IsSplitOutputSelected, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Nomes dos arquivos (modo separado)" FontWeight="SemiBold" />
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Arquivo público" FontSize="12" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                            <TextBox Text="{Binding PublicPemFileName, Mode=TwoWay}" PlaceholderText="Ex: meu-certificado.cert.pem" />
                                        </StackPanel>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Arquivo privado" FontSize="12" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                            <TextBox Text="{Binding PrivatePemFileName, Mode=TwoWay}" PlaceholderText="Ex: meu-certificado.key.pem" />
                                        </StackPanel>
                                        <TextBlock Text="Obrigatório: público termina com .cert.pem e privado termina com .key.pem."
                                                   FontSize="12"
                                                   Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Prévia do arquivo gerado" FontSize="12" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                        <TextBlock Text="{Binding CombinedOutputFileNamePreview, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource ApplicationTextBrush}"
                                                   Opacity="0.8" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="16">
                            <TextBlock Text="Execução" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <Border Style="{StaticResource SectionCardStyle}" Background="{ThemeResource ApplicationSurfaceBrush}">
                                <StackPanel Spacing="14">
                                    <Grid>
                                        <TextBlock Text="Progresso" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ProgressPercentage, Mode=OneWay}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#009628"
                                                   FontWeight="Bold" FontSize="16" />
                                    </Grid>

                                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Foreground="#009628" Height="8" CornerRadius="4" />

                                    <TextBlock Text="{Binding Status, Mode=OneWay}"
                                               FontSize="13"
                                               Foreground="{ThemeResource ApplicationSubTextBrush}"
                                               FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"
                                               ToolTipService.ToolTip="{Binding Status, Mode=OneWay}" />

                                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                                        <Button Content="Cancelar" Click="CancelButton_Click" IsEnabled="{Binding IsProcessing}" />
                                        <Button Content="Executar Exportação"
                                                Background="{ThemeResource ApplicationAccentBrush}"
                                                Foreground="White"
                                                FontWeight="Bold"
                                                Padding="24,10"
                                                Click="RunButton_Click"
                                                IsEnabled="{Binding CanRun}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Log" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,8" />

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                                        <ToggleSwitch Header="Auto-scroll" IsOn="{Binding AutoScrollEnabled, Mode=TwoWay}" />
                                        <Button Content="Copiar log" Click="CopyLogButton_Click" />
                                        <Button Content="Limpar" Click="ClearLogButton_Click" />
                                    </StackPanel>

                                    <TextBox x:Name="LogTextBox"
                                             Text="{Binding LogText, Mode=TwoWay}"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             IsReadOnly="True"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             MinHeight="220"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             TextChanged="LogTextBox_TextChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- NEW VALIDATION SECTION -->
                <StackPanel x:Name="ValidationSection" Spacing="16" Visibility="Collapsed" DataContext="{x:Bind ValidationViewModel}">
                    
                    <InfoBar IsOpen="{Binding IsErrorVisible}"
                             Severity="Error"
                             Title="Atenção"
                             Message="{Binding ErrorText}"
                             IsClosable="False"
                             Margin="0,0,0,4" />

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <!-- Input Grid -->
                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Entrada" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Arquivo do certificado" FontWeight="SemiBold" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding InputCertificatePath, Mode=TwoWay}" PlaceholderText="Selecione um .pfx/.p12/.cer/.crt" />
                                            <Button Grid.Column="1" Click="BrowseValidationCertificateButton_Click" ToolTipService.ToolTip="Escolher arquivo">
                                                <FontIcon Glyph="&#xED25;" FontSize="16" FontFamily="Segoe Fluent Icons" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="6" Visibility="{Binding IsPasswordRequired, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Senha do certificado" FontWeight="SemiBold" />
                                        <PasswordBox Password="{Binding Password, Mode=TwoWay}" PlaceholderText="Senha do .pfx/.p12" />
                                    </StackPanel>
                                    
                                    <Button Content="Validar Certificado"
                                            Background="{ThemeResource ApplicationAccentBrush}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Padding="24,10"
                                            HorizontalAlignment="Stretch"
                                            Click="ValidateButton_Click"
                                            IsEnabled="{Binding CanRun}" />
                                            
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                                        <ProgressRing IsActive="True" Width="20" Height="20" />
                                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                                <Button Content="Limpar" Click="ClearValidationButton_Click" />
                                <Button Content="Copiar Resumo" Click="CopyValidationSummaryButton_Click" />
                                <Button Content="Copiar Thumbprint" Click="CopyThumbprintButton_Click" />
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Output Grid -->
                        <StackPanel Grid.Column="1" Spacing="16" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <TextBlock Text="Detalhes do Certificado" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Border HorizontalAlignment="Right" Background="{Binding BadgeColorBrush}" Padding="12,4" CornerRadius="4">
                                    <TextBlock Text="{Binding DaysRemaining}" Foreground="White" FontWeight="Bold" FontSize="12" />
                                </Border>
                            </Grid>
                            
                            <Border Style="{StaticResource SectionCardStyle}">
                                <Grid RowSpacing="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome do arquivo:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileName}" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Emitido para (Subject):" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subject}" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Emitido por (Issuer):" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Issuer}" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Válido de:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NotBefore}" />
                                    
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Válido até:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NotAfter}" />
                                    
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Expirado:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding IsExpiredText}" />
                                    
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Thumbprint SHA1:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Thumbprint}" FontFamily="Consolas" />
                                    
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Serial Number:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SerialNumber}" FontFamily="Consolas" />
                                    
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Algoritmo da assinatura:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SignatureAlgorithm}" />
                                    
                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Possui chave privada:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding HasPrivateKeyText}" />
                                    
                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Tipo da chave:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding KeyAlgorithm}" />
                                    
                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="Tamanho da chave:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding KeySize}" />
                                    
                                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Friendly Name:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" />
                                    <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding FriendlyName}" TextWrapping="Wrap" />
                                    
                                    <TextBlock Grid.Row="13" Grid.Column="0" Text="SAN / DNS Names:" FontWeight="SemiBold" Foreground="{ThemeResource ApplicationSubTextBrush}" Margin="0,0,16,0" />
                                    <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding SubjectAlternativeNames}" TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
