# =========================================
# DevSAK - Git Attributes
# =========================================

# Normalize text files automatically
* text=auto

# =========================
# Source code
# =========================

*.cs          text diff=csharp
*.csproj      text
*.sln         text
*.xaml        text
*.json        text
*.xml         text
*.config      text
*.md          text
*.txt         text
*.yml         text
*.yaml        text
*.ps1         text
*.cmd         text
*.bat         text

# =========================
# Force line endings
# =========================

*.cs          text eol=crlf
*.csproj      text eol=crlf
*.sln         text eol=crlf
*.xaml        text eol=crlf

# =========================
# Binary files
# =========================

*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.dll         binary
*.exe         binary
*.zip         binary
*.7z          binary
*.rar         binary
*.pfx         binary
*.p12         binary
*.snk         binary
*.pdf         binary

# =========================
# Archives / packages
# =========================

*.nupkg       binary
*.snupkg      binary
*.msix        binary
*.appx        binary

# =========================
# GitHub linguist
# =========================

*.xaml linguist-language=XML